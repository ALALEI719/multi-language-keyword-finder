# ========== 飞书 + 大模型（摘要）==========
FEISHU_WEBHOOK_URL=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ========== 方式 A：免 Apify —— X 官方 API + 你关注的 KOL 主页 ==========
# 在 https://developer.twitter.com 创建 Project/App，生成 Bearer Token（只读推文需有对应权限与配额）。
TWITTER_BEARER_TOKEN=
# 多列用英文逗号分隔；也支持每行一个（换行后保存）。
# 示例：https://x.com/ahrefs,https://x.com/rustybrick
X_KOL_PROFILE_URLS=
# 每个 KOL 最多拉多少条（5–100，单次请求上限由 X 决定）
TWITTER_TWEETS_PER_KOL=30
# 若希望「KOL 发什么都进候选」，设为 true（否则只保留正文里出现 SEO_KEYWORDS 的推文）
X_KOL_SKIP_KEYWORD_FILTER=false

# ========== 方式 B：免 Apify —— RSS（博客、资讯、或第三方「LinkedIn→RSS」服务生成的地址）==========
RSS_FEED_URLS=
# 是否要求标题/摘要里命中 SEO_KEYWORDS（建议 true，噪音更少）
RSS_MATCH_KEYWORDS=true

# ========== 方式 C：Apify（关键词搜全站热帖，可不配 KOL）==========
APIFY_API_TOKEN=
APIFY_TWITTER_ACTOR=apidojo/tweet-scraper
APIFY_LINKEDIN_ACTOR=benjarapi/linkedin-post-search
APIFY_WAIT_SEC=300
TWITTER_MAX_ITEMS=120
LINKEDIN_MAX_POSTS=80

# ========== 业务参数 ==========
SEO_KEYWORDS=seo,technical seo,international seo,search intent,google updates
POSTS_HOURS_WINDOW=24

# ========== 方式 D：自建 HTTP 接口（覆盖对应平台）==========
X_POSTS_API_URL=
X_POSTS_API_KEY=
LINKEDIN_POSTS_API_URL=
LINKEDIN_POSTS_API_KEY=
